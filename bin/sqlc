#!/bin/bash
set -e

# Check for sqlc
if ! command -v sqlc &> /dev/null; then
  echo "Error: sqlc is not installed. Run: brew install sqlc"
  exit 1
fi

# Ensure queries directory and file exist
mkdir -p db/queries
if [ ! -f db/queries/query.sql ]; then
  echo "-- Write your queries here" > db/queries/query.sql
fi

# Generate Go code from SQL queries
sqlc generate

echo "sqlc generation complete. Output in internal/db/"
