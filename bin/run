#!/bin/bash
set -euo pipefail

pushd "$(dirname "$0")/.." >/dev/null

DB_HOST="${DB_HOST:-localhost}"
DB_PORT="${DB_PORT:-5432}"

check_postgres() {
  if ! nc -z "$DB_HOST" "$DB_PORT" 2>/dev/null; then
    echo "Error: Postgres is not reachable at ${DB_HOST}:${DB_PORT}"
    echo "Start it with: docker compose up -d"
    exit 1
  fi
}

usage() {
  echo "Usage: ./bin/run [options] <service> [args...]"
  echo ""
  echo "Options:"
  echo "  -d, --debug   Enable debug logs (sets LOG_LEVEL=debug)"
  echo "  -h, --help    Show this help message"
  echo ""
  echo "Services:"
  echo "  queue      (q)"
  echo "  producer   (p)"
  echo "  worker     (w)"
  echo ""
  echo "Examples:"
  echo "  bin/run queue"
  echo "  bin/run --debug worker"
  echo "  bin/run -d queue"
  echo "  bin/run -d producer"
  echo "  bin/run q"
  exit 1
}

DEBUG_MODE=0

while [ $# -gt 0 ]; do
  case "${1}" in
    -d|--debug)
      DEBUG_MODE=1
      shift
      ;;
    -h|--help)
      usage
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "Error: unknown option '${1}'"
      usage
      ;;
    *)
      break
      ;;
  esac
done

if [ -z "${1:-}" ]; then
  usage
fi

TARGET="$1"
shift

# Resolve short aliases
case "$TARGET" in
  q) TARGET="queue" ;;
  p) TARGET="producer" ;;
  w) TARGET="worker" ;;
esac

if [ ! -d "./cmd/${TARGET}" ]; then
  echo "Error: unknown service '${TARGET}'"
  usage
fi

if [ "$DEBUG_MODE" -eq 1 ]; then
  export LOG_LEVEL=debug
  echo "Debug mode enabled (LOG_LEVEL=debug)"
fi

check_postgres
echo "Running ${TARGET}..."
go run "./cmd/${TARGET}" "$@"
