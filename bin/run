#!/bin/bash
set -euo pipefail

pushd "$(dirname "$0")/.." >/dev/null

DB_HOST="${DB_HOST:-localhost}"
DB_PORT="${DB_PORT:-5432}"

check_postgres() {
  if ! nc -z "$DB_HOST" "$DB_PORT" 2>/dev/null; then
    echo "Error: Postgres is not reachable at ${DB_HOST}:${DB_PORT}"
    echo "Start it with: docker compose up -d"
    exit 1
  fi
}

usage() {
  echo "Usage: ./bin/run <producer|worker> [args...]"
  echo ""
  echo "Commands:"
  echo "  producer   Run the producer service"
  echo "  worker     Run the worker service"
  exit 1
}

if [ -z "${1:-}" ]; then
  usage
fi

TARGET="$1"
shift

case "$TARGET" in
  producer|worker)
    check_postgres
    echo "Running ${TARGET}..."
    go run "./cmd/${TARGET}" "$@"
    ;;
  *)
    usage
    ;;
esac
